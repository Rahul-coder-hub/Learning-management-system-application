{
    "name": "lms-system-root",
    "version": "1.0.0",
    "workspaces": [
        "frontend",
        "backend"
    ],
    "scripts": {
        "install:all": "npm install",
        "build": "npm run build --workspace=frontend",
        "dev": "npx concurrently \"npm run start --workspace=backend\" \"npm run dev --workspace=frontend\"",
        "start:backend": "npm run start --workspace=backend",
        "start:frontend": "npm run dev --workspace=frontend"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}